APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql

# Master Database Configuration (for tenant management)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=tenant_master
DB_USERNAME=root
DB_PASSWORD=

# Tenant Database Configuration
TENANT_DB_PREFIX=tenant_
TENANT_DB_HOST=127.0.0.1
TENANT_DB_PORT=3306
TENANT_DB_USERNAME=root
TENANT_DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Sanctum Configuration
SANCTUM_STATEFUL_DOMAINS=localhost,127.0.0.1
SANCTUM_TOKEN_EXPIRATION=10080

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000

# SSLCommerz (Bangladesh Payment Gateway)
SSLCOMMERZ_STORE_ID=your_store_id
SSLCOMMERZ_STORE_PASSWORD=your_store_password
SSLCOMMERZ_SANDBOX=true

# Middle East Payment Gateways
# Moyasar (MADA + Visa/MC + Apple Pay - KSA native)
MOYASAR_PUBLISHABLE_KEY=pk_test_xxxx
MOYASAR_SECRET_KEY=sk_test_xxxx
MOYASAR_WEBHOOK_SECRET=wh_xxxx
MOYASAR_SANDBOX=true

# STC Pay (Saudi wallet)
STC_PAY_MERCHANT_ID=
STC_PAY_API_KEY=
STC_PAY_SANDBOX=true

# Tabby BNPL (4 splits - UAE + KSA)
TABBY_PUBLIC_KEY=
TABBY_SECRET_KEY=
TABBY_MERCHANT_CODE=
TABBY_SANDBOX=true

# Tamara BNPL (3 splits - strong in KSA)
TAMARA_API_TOKEN=
TAMARA_NOTIFY_TOKEN=
TAMARA_SANDBOX=true

# Postpay BNPL (UAE)
POSTPAY_API_KEY=
POSTPAY_SANDBOX=true

# VAT / Compliance
UAE_TRN=
VAT_REGISTRATION_NUMBER=
APP_FRONTEND_URL=http://localhost:4000

# --- Tenant Domain Config --------------------------------------
# Local: TENANT_CENTRAL_DOMAIN=localhost
# Production: TENANT_CENTRAL_DOMAIN=pixelmasters.io
TENANT_CENTRAL_DOMAIN=localhost
TENANT_CENTRAL_DOMAIN_2=


# --- Stripe Billing ---------------------------------------------------
STRIPE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_SECRET=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs (from Stripe Dashboard > Products > Prices)
# These are the recurring subscription price IDs per plan tier.
STRIPE_PRICE_PRO=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_BUSINESS=price_xxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_ENTERPRISE=price_xxxxxxxxxxxxxxxxxxxx
